# ========== 数据库 ==========
POSTGRES_USER=ragadmin
POSTGRES_PASSWORD=change_me_plz
POSTGRES_DB=knowledge_rag
DATABASE_URL=postgresql+asyncpg://ragadmin:change_me_plz@postgres:5432/knowledge_rag

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== RabbitMQ ==========
RABBITMQ_URL=amqp://guest:***@rabbitmq:5672//

# ========== MinIO ==========
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-rag

# ========== JWT ==========
SECRET_KEY=***-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PRODUCTION_MAX_TOKEN_MINUTES=120

# ========== LLM API ==========
# DeepSeek V4（主力模型）
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-chat

# 通义千问（仅多模态看图用，纯文本对话不需要）
DASHSCOPE_API_KEY=

# ========== Embedding ==========
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ========== 管理员账号 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# ========== 应用配置 ==========
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true
MAX_UPLOAD_SIZE_MB=50
USE_MINIO=false

# ========== Production controls ==========
# Prefer NAME_FILE paths mounted from Docker/Kubernetes secrets.
SECRET_KEY_FILE=
ADMIN_PASSWORD_FILE=
DEEPSEEK_API_KEY_FILE=
DASHSCOPE_API_KEY_FILE=
MINIO_SECRET_KEY_FILE=
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET_FILE=
OIDC_REDIRECT_URI=http://localhost:8080/api/sso/oidc/callback
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=example,dc=com
LDAP_USE_SSL=true
CLAMAV_ENABLED=false
CLAMAV_HOST=clamav
FILE_SCAN_FAIL_CLOSED=true
RATE_LIMIT_PER_MINUTE=120
DAILY_REQUEST_QUOTA=5000
MAX_CONCURRENT_EXPENSIVE_REQUESTS=8
CONVERSATION_RETENTION_DAYS=90
DOCUMENT_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=365
OPENSEARCH_ENABLED=false
OPENSEARCH_URL=http://opensearch:9200
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
INTENT_ROUTER_USE_LLM=true
INTENT_ROUTER_CONFIDENCE_THRESHOLD=0.65
RAG_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=600
ANSWER_CACHE_TTL_SECONDS=900
INTENT_CACHE_TTL_SECONDS=3600
REFLECTION_ENABLED=true
REFLECTION_USE_LLM=true
LONG_TERM_MEMORY_ENABLED=true
LONG_TERM_MEMORY_TOP_K=3
LONG_TERM_MEMORY_MAX_PER_USER=100
